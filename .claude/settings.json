{
  "$schema": "https://json.schemastore.org/claude-code-settings.json",
  "permissions": {
    "allow": [
      "Bash(uv *)",
      "Bash(uv sync*)",
      "Bash(uv run *)",
      "Bash(uv pip *)",
      "Bash(git diff*)",
      "Bash(git status*)",
      "Bash(git log*)",
      "Bash(git show*)",
      "Bash(git blame*)",
      "Bash(python *.py)",
      "Bash(python -c *)",
      "Read(./**)",
      "Write(notebooks/**)",
      "Write(manuscripts/**)",
      "Write(artifacts/**)",
      "Write(data/**)",
      "Edit(notebooks/**)",
      "Edit(manuscripts/**)",
      "Edit(pyproject.toml)",
      "Edit(jellycell.toml)",
      "Edit(README.md)",
      "Edit(CLAUDE.md)"
    ],
    "deny": [
      "Bash(rm -rf*)",
      "Bash(git push*)",
      "Bash(git reset --hard*)",
      "Write(.venv/**)"
    ]
  },
  "env": {
    "UV_PROJECT_ENVIRONMENT": ".venv",
    "PYTHONDONTWRITEBYTECODE": "1"
  }
}
